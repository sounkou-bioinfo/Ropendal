TARGET = @TARGET@

PROFILE = @PROFILE@
FEATURE_FLAGS = @FEATURE_FLAGS@
TARGET_FLAG = $(if $(TARGET),--target $(TARGET),)

RUSTFLAGS =

TARGET_DIR = $(CURDIR)/rust/target
LIBDIR = $(TARGET_DIR)/$(TARGET)/$(subst dev,debug,$(PROFILE))

ifeq ($(TARGET),wasm32-unknown-emscripten)
OBJECTS = init.o capi_anchor.o wasm_stubs.o
PKG_LIBS =

all: $(SHLIB)

clean_intermediate:

clean:
	rm -Rf $(SHLIB) $(OBJECTS) ./rust/target

else
OBJECTS = capi_anchor.o init.o
STATLIB = $(LIBDIR)/libropendal.a
PKG_LIBS = -L$(LIBDIR) -lropendal

CARGO_BUILD_ARGS = $(TARGET_FLAG) --lib --profile $(PROFILE) $(FEATURE_FLAGS) --manifest-path=./rust/Cargo.toml --target-dir $(TARGET_DIR)

all: $(SHLIB) clean_intermediate

$(SHLIB): $(STATLIB)

$(STATLIB):
	if [ -f ./rust/vendor.tar.xz ]; then \
	  tar xf ./rust/vendor.tar.xz -C ./rust; \
	fi
	export PATH="$(PATH):$(HOME)/.cargo/bin" && \
	  export CC="$(CC)" && \
	  export CFLAGS="$(CFLAGS)" && \
	  export RUSTFLAGS="$(RUSTFLAGS)" && \
	  @BEFORE_CARGO_BUILD@ \
	  cargo build $(CARGO_BUILD_ARGS)

clean_intermediate: $(SHLIB)
	rm -Rf $(TARGET_DIR)

clean:
	rm -Rf $(SHLIB) $(OBJECTS) $(STATLIB) ./rust/target
endif

.PHONY: all clean_intermediate clean
