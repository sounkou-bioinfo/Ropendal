TARGET = @TARGET@

PROFILE = @PROFILE@
FEATURE_FLAGS = @FEATURE_FLAGS@

RUSTFLAGS =

# Keep wasm_stubs.c out of native Windows builds. R's Windows make rules
# otherwise compile every C source in src/, which would override the real
# Rust/OpenDAL implementation with the webR unsupported shim.
OBJECTS = capi_anchor.o init.o

TARGET_DIR = $(CURDIR)/rust/target
LIBDIR = $(TARGET_DIR)/$(TARGET)/$(subst dev,debug,$(PROFILE))
STATLIB = $(LIBDIR)/libropendal.a
PKG_LIBS = -L$(LIBDIR) -lropendal -lws2_32 -ladvapi32 -luserenv -lbcrypt -lntdll

CARGO_LINKER = x86_64-w64-mingw32.static.posix-gcc.exe

all: $(SHLIB) clean_intermediate

$(SHLIB): $(STATLIB)

$(STATLIB):
	mkdir -p $(LIBDIR)/libgcc_mock && touch $(LIBDIR)/libgcc_mock/libgcc_eh.a
	export CARGO_TARGET_X86_64_PC_WINDOWS_GNU_LINKER="$(CARGO_LINKER)" && \
	  export LIBRARY_PATH="$${LIBRARY_PATH};$(LIBDIR)/libgcc_mock" && \
	  export CC="$(CC)" && \
	  export CFLAGS="$(CFLAGS)" && \
	  export RUSTFLAGS="$(RUSTFLAGS)" && \
	  cargo build --target $(TARGET) --lib --profile $(PROFILE) $(FEATURE_FLAGS) --manifest-path ./rust/Cargo.toml --target-dir $(TARGET_DIR)

clean_intermediate: $(SHLIB)
	rm -Rf $(TARGET_DIR)

clean:
	rm -Rf $(SHLIB) $(OBJECTS) $(STATLIB) ./rust/target

.PHONY: all clean_intermediate clean
